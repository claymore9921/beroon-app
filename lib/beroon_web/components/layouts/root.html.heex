<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="برون" suffix="" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <% current_role = assigns[:current_user_role] %>
    <% show_menu = current_role == "admin" %>

    <header class="beroon-app-header">
      <div class={[
        "beroon-header-inner",
        current_role == "branch_manager" && "beroon-header-inner-manager"
      ]}>
        <div class="beroon-header-side beroon-header-menu-side">
          <details :if={show_menu} class="beroon-mobile-menu">
            <summary aria-label="باز کردن منو">
              <.icon name="hero-bars-3" class="size-6" />
            </summary>
            <nav class="beroon-menu-panel" aria-label="منوی اصلی">
              <div class="beroon-menu-head">
                <img src={~p"/images/logo.svg"} alt="برون" />
                <div>
                  <p>برون</p>
                  <span>پنل ادمین</span>
                </div>
              </div>

              <div class="beroon-menu-list">
                <.link navigate={~p"/admin/reports"}><.icon name="hero-home" />داشبورد</.link>
                <.link navigate={~p"/checklist_items"}>
                  <.icon name="hero-clipboard-document-check" />چک‌لیست‌ها
                </.link>
                <.link navigate={~p"/admin/checklists"}>
                  <.icon name="hero-document-chart-bar" />گزارش چک‌لیست
                </.link>
                <.link navigate={~p"/admin/evening-reports"}>
                  <.icon name="hero-chart-bar-square" />گزارش آمارگیری
                </.link>
                <.link navigate={~p"/admin/location-alerts"}>
                  <.icon name="hero-map-pin" />گزارش جابجایی
                </.link>
                <.link navigate={~p"/admin/managers"}>
                  <.icon name="hero-user-plus" />تایید مدیران
                </.link>
                <.link navigate={~p"/scooters"}><.icon name="hero-qr-code" />دستگاه‌ها</.link>
                <.link navigate={~p"/device_types"}>
                  <.icon name="hero-squares-2x2" />نوع دستگاه
                </.link>
                <.link navigate={~p"/branches"}>
                  <.icon name="hero-building-storefront" />شعبه‌ها
                </.link>
              </div>

              <.link href={~p"/logout"} method="delete" class="beroon-menu-logout">
                <.icon name="hero-arrow-right-on-rectangle" />خروج
              </.link>
            </nav>
          </details>
        </div>

        <a href="/" class="beroon-header-logo" aria-label="برون">
          <img src={~p"/images/logo.svg"} alt="برون" />
        </a>

        <div class="beroon-header-side beroon-header-title-side">
          <p :if={current_role == "admin"} class="beroon-header-branch-name">
            ادمین
          </p>
        </div>
      </div>
    </header>

    {@inner_content}
  </body>
</html>
